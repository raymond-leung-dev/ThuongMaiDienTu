@model DoGiaDung.Domain.Entities.Catalog
@{ ViewData["Title"] = "Editar"; }
<h1>@Lang.Get("BTN_EDIT"): @Model.CatalogName</h1>
<form method="post">
    <div class="mb-3"><label>@Lang.Get("TBL_PRODUCT_NAME")</label><input name="CatalogName" value="@Model.CatalogName" class="form-control" /></div>
    <button type="submit" class="btn btn-primary">@Lang.Get("BTN_SAVE")</button>
</form>
