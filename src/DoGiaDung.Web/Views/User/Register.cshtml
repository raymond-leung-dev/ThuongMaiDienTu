@{
    ViewData["Title"] = "Registrarse";
}

<h2>Crear una cuenta</h2>

@if (!string.IsNullOrEmpty(ViewBag.Error))
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

<form method="post" asp-action="Register">
    <div class="mb-3">
        <label>Nombre completo</label>
        <input name="FullName" class="form-control" required />
    </div>
    <div class="mb-3">
        <label>Email</label>
        <input name="Email" type="email" class="form-control" required />
    </div>
    <div class="mb-3">
        <label>Teléfono</label>
        <input name="Phone" type="tel" class="form-control" required placeholder="+34612345678" />
    </div>
    <div class="mb-3">
        <label>Contraseña (min. 8 caracteres)</label>
        <input name="Password" type="password" class="form-control" required minlength="8" />
    </div>
    <div class="mb-3">
        <label>Dirección</label>
        <input name="Address" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Crear cuenta</button>
    <a asp-action="Index" class="btn btn-link">Ya tengo cuenta</a>
</form>
