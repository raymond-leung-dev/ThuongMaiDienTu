@{
    Layout = "_AdminLayoutLogin";
    ViewData["Title"] = Lang.GetRaw("TTL_LOGIN");
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-xl-10 col-lg-12 col-md-9">
            <div class="card o-hidden border-0 shadow-lg my-5">
                <div class="card-body p-0">
                    <div class="row">
                        <div class="col-lg-6 d-none d-lg-block" style="background-image: url('/admin-images/images.png'); background-repeat: no-repeat; background-position: center; background-size: contain;"></div>
                        <div class="col-lg-6">
                            <div class="p-5">
                                <div class="text-center">
                                    <h1 class="h4 text-gray-900 mb-4">@Lang.Get("MSG_DASHBOARD_WELCOME")</h1>
                                </div>
                                <form method="post" asp-action="Login" class="user">
                                    @if (!string.IsNullOrEmpty(ViewBag.ErrorInfo))
                                    {
                                        <p class="text-danger">@ViewBag.ErrorInfo</p>
                                    }
                                    <div class="form-group">
                                        <input type="text" class="form-control form-control-user"
                                               name="username" placeholder="Username" />
                                    </div>
                                    <div class="form-group">
                                        <input type="password" class="form-control form-control-user"
                                               name="password" placeholder="Password" />
                                    </div>
                                    <div class="form-group">
                                        <div class="custom-control custom-checkbox small">
                                            <input type="checkbox" class="custom-control-input" id="customCheck">
                                            <label class="custom-control-label" for="customCheck">@Lang.Get("MSG_ALREADY_ACCOUNT")</label>
                                        </div>
                                    </div>
                                    <button type="submit" class="btn btn-danger btn-user btn-block">@Lang.Get("BTN_LOGIN")</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
