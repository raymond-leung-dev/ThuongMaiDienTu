<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — DoGiaDung</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">DoGiaDung</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navmenu">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navmenu">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">@* NAV_HOME *@Inicio</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Contact">@* NAV_CONTACT *@Contacto</a></li>
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item"><span class="nav-link text-light">@User.Identity.Name</span></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="User" asp-action="Logout">@* NAV_LOGOUT *@Cerrar Sesión</a></li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="User" asp-action="Index">@* NAV_LOGIN *@Iniciar Sesión</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="User" asp-action="Register">@* NAV_REGISTER *@Registrarse</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="container mt-4">
        @RenderBody()
    </main>

    <footer class="border-top footer text-muted mt-5 py-3">
        <div class="container text-center">
            &copy; 2026 DoGiaDung — Todos los derechos reservados
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
