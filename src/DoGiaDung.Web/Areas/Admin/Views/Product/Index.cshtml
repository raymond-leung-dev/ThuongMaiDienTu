@model IEnumerable<DoGiaDung.Application.DTOs.ProductDto>
@{
    ViewData["Title"] = "Productos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Productos</h1>
    <a asp-action="Create" class="btn btn-primary">+ Nuevo Producto</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Precio</th>
            <th>Stock</th>
            <th>Categoría</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null)
        {
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.ProductName</td>
                    <td>@p.PriceWithVat.ToString("C2", new System.Globalization.CultureInfo("es-ES"))</td>
                    <td>@(p.Quantity?.ToString() ?? "-")</td>
                    <td>@p.CatalogName</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@p.ProductId" class="btn btn-sm btn-warning">Editar</a>
                        <form asp-action="Delete" asp-route-id="@p.ProductId" method="post" class="d-inline"
                              onsubmit="return confirm('¿Eliminar este producto?')">
                            <button type="submit" class="btn btn-sm btn-danger">Eliminar</button>
                        </form>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
