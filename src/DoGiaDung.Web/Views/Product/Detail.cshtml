@model DoGiaDung.Application.DTOs.ProductDto
@{
    ViewData["Title"] = Model.ProductName;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">@Lang.Get("NAV_HOME")</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">@Lang.Get("NAV_PRODUCT")</a></li>
        <li class="breadcrumb-item active">@Model.ProductName</li>
    </ol>
</nav>

<div class="row">
    <div class="col-md-6">
        @if (!string.IsNullOrEmpty(Model.ImageLink))
        {
            <img src="@Model.ImageLink" class="img-fluid rounded" alt="@Model.ProductName" />
        }
    </div>
    <div class="col-md-6">
        <h1>@Model.ProductName</h1>
        <h2 class="text-success">@Model.PriceWithVat.ToString("C2", new System.Globalization.CultureInfo("es-ES"))</h2>
        <p><small class="text-muted">@Lang.Get("MSG_VAT_INCLUDED") (@(Model.VatRate * 100)%)</small></p>
        <p>@Model.Description</p>

        @if (Model.CatalogName != null)
        {
            <p>@Lang.Get("LBL_CATALOG"): @Model.CatalogName</p>
        }

        @if (Model.Quantity.HasValue && Model.Quantity > 0)
        {
            <p class="text-success">@Lang.Get("MSG_IN_STOCK")</p>
            <a asp-controller="Cart" asp-action="Add" asp-route-id="@Model.ProductId" class="btn btn-primary btn-lg">@Lang.Get("BTN_ADD_TO_CART")</a>
        }
        else
        {
            <p class="text-danger">@Lang.Get("MSG_OUT_OF_STOCK")</p>
        }
    </div>
</div>
