@model DoGiaDung.Application.DTOs.ResetPasswordDto
@{ ViewData["Title"] = Lang.GetRaw("BTN_FORGOT_PASS"); }
<h2>@Lang.Get("BTN_FORGOT_PASS")</h2>
<form method="post" asp-action="ResetPassword">
    <input type="hidden" asp-for="ResetCode" />
    <div class="mb-3"><label>@Lang.Get("LBL_PASSWORD")</label><input asp-for="NewPassword" type="password" class="form-control" /></div>
    <div class="mb-3"><label>Confirmar</label><input asp-for="ConfirmPassword" type="password" class="form-control" /></div>
    <button type="submit" class="btn btn-primary">@Lang.Get("BTN_SUBMIT")</button>
</form>
