@{ ViewData["Title"] = Lang.GetRaw("BTN_FORGOT_PASS"); }
<h2>@Lang.Get("BTN_FORGOT_PASS")</h2>
@if (!string.IsNullOrEmpty(ViewBag.Message)) { <div class="alert alert-info">@ViewBag.Message</div> }
<form method="post" asp-action="ForgotPassWord">
    <div class="mb-3"><label>@Lang.Get("LBL_EMAIL")</label><input name="EmailID" type="email" class="form-control" required /></div>
    <button type="submit" class="btn btn-primary">@Lang.Get("BTN_SUBMIT")</button>
</form>
