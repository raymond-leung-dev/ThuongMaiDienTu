@model IEnumerable<DoGiaDung.Domain.Entities.Slide>
@{ ViewData["Title"] = Lang.GetRaw("NAV_ADM_SLIDES"); }
<h1>@Lang.Get("NAV_ADM_SLIDES")</h1>
<a asp-action="Create" class="btn btn-primary mb-3">@Lang.Get("BTN_NEW_PRODUCT")</a>
<table class="table"><thead><tr><th>@Lang.Get("TBL_PRODUCT_NAME")</th><th>@Lang.Get("TBL_ACTIONS")</th></tr></thead><tbody>
@foreach (var s in Model ?? Enumerable.Empty<DoGiaDung.Domain.Entities.Slide>())
{
    <tr>
        <td>@s.Title</td>
        <td>
            <form asp-action="Delete" asp-route-id="@s.SlideId" method="post" class="d-inline" onsubmit="return confirm('@Lang.GetRaw("MSG_CONFIRM_DELETE")')"><button type="submit" class="btn btn-sm btn-danger">@Lang.Get("BTN_DELETE")</button></form>
        </td>
    </tr>
}
</tbody></table>
