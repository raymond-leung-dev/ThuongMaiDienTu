@model DoGiaDung.Application.DTOs.ProductDto
@{
    ViewData["Title"] = Model.ProductName;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Inicio</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Productos</a></li>
        <li class="breadcrumb-item active">@Model.ProductName</li>
    </ol>
</nav>

<div class="row">
    <div class="col-md-6">
        @if (!string.IsNullOrEmpty(Model.ImageLink))
        {
            <img src="@Model.ImageLink" class="img-fluid rounded" alt="@Model.ProductName" />
        }
    </div>
    <div class="col-md-6">
        <h1>@Model.ProductName</h1>
        <h2 class="text-success">@Model.PriceWithVat.ToString("C2", new System.Globalization.CultureInfo("es-ES"))</h2>
        <p><small class="text-muted">IVA @(Model.VatRate * 100)% incluido</small></p>

        <p>@Model.Description</p>

        @if (Model.Quantity.HasValue && Model.Quantity > 0)
        {
            <p class="text-success">En stock</p>
            <a asp-controller="Cart" asp-action="Add" asp-route-id="@Model.ProductId" class="btn btn-primary btn-lg">Añadir al Carrito</a>
        }
        else
        {
            <p class="text-danger">Agotado</p>
        }
    </div>
</div>
