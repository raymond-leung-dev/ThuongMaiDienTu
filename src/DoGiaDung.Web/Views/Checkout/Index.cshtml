@model DoGiaDung.Application.DTOs.CartDto
@{
    ViewData["Title"] = Lang.GetRaw("TTL_CHECKOUT");
}

<h2>@Lang.Get("TTL_CHECKOUT")</h2>

<table class="table">
    <thead><tr><th>@Lang.Get("TBL_PRODUCT_NAME")</th><th>@Lang.Get("LBL_QUANTITY")</th><th>@Lang.Get("LBL_TOTAL")</th></tr></thead>
    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.ProductName</td>
                <td>@item.Quantity</td>
                <td>@item.Total.ToString("C2", new System.Globalization.CultureInfo("es-ES"))</td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr><td colspan="2" class="text-end fw-bold">@Lang.Get("LBL_TOTAL"):</td><td class="fw-bold">@Model.Total.ToString("C2", new System.Globalization.CultureInfo("es-ES"))</td></tr>
    </tfoot>
</table>

<form method="post" asp-action="PlaceOrder">
    <div class="mb-3">
        <label>@Lang.Get("LBL_SHIPPING_ADDRESS")</label>
        <input name="address" class="form-control" required />
    </div>
    <div class="mb-3">
        <label>@Lang.Get("LBL_ORDER_NOTE")</label>
        <textarea name="message" class="form-control"></textarea>
    </div>
    <div class="text-danger mb-3" asp-validation-summary="All"></div>
    <button type="submit" class="btn btn-success btn-lg">@Lang.Get("BTN_PAY_STRIPE")</button>
</form>
